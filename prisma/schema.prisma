// Prisma schema — APATS
// Modèles métier ajoutés dans F-002

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MEMBER
}

enum Locale {
  fr
  en
}

enum MeetingType {
  BUREAU
  AG
  EXTRAORDINARY
}

enum PaymentMode {
  CASH
  WAVE
  ORANGE_MONEY
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum Feature {
  // Membres
  MEMBERS_VIEW
  MEMBERS_VIEW_DETAIL
  MEMBERS_EXPORT
  // Cotisations
  COTISATIONS_VIEW
  COTISATIONS_MANAGE
  COTISATIONS_CONFIRM
  // Réunions
  MEETINGS_VIEW
  MEETINGS_CREATE
  MEETINGS_ATTENDANCE
  MEETINGS_UPLOAD_PV
  // Événements
  EVENTS_VIEW
  EVENTS_CREATE
  // Trésorerie
  TREASURY_VIEW
  TREASURY_MANAGE
  TREASURY_EXPORT
  // Communication (lecture = tous les membres authentifiés, cf. CDC §5.8)
  ANNOUNCEMENTS_CREATE
}

// ---------------------------------------------------------------------------
// Modèles
// ---------------------------------------------------------------------------

model MemberCategory {
  id         String   @id @default(cuid())
  name       String   @unique // ex: "CDI", "CDD", "Vacation"
  monthlyFee Int               // montant mensuel en FCFA
  users      User[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  name                 String
  passwordHash         String
  role                 Role            @default(MEMBER)
  locale               Locale          @default(fr)
  categoryId           String?
  category             MemberCategory? @relation(fields: [categoryId], references: [id])
  mandates             Mandate[]
  notifications        Notification[]
  memberCards          MemberCard[]
  monthlyPayments      MonthlyPayment[]
  passwordResetToken   String?         @unique
  passwordResetExpiry  DateTime?
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Post {
  id          String       @id @default(cuid())
  name        String       @unique // ex: "Président", "Trésorier", "Secrétaire"
  permissions Permission[]
  mandates    Mandate[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id      String  @id @default(cuid())
  postId  String
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  feature Feature
  granted Boolean @default(true)

  @@unique([postId, feature])
}

model Mandate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Restrict)
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "mandate_expiry" | "cotisation_due" | "meeting_invite" | "announcement"
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model AppConfig {
  id                   String   @id @default("singleton")
  orgName              String   @default("Amicale des PATs — ENSMG")
  logoUrl              String?
  defaultLocale        Locale   @default(fr)
  academicYear         String   @default("2025-2026")
  mandateDurationDays  Int      @default(730) // 2 ans par défaut (CDC §5.2.3)
  cardPriceFcfa        Int      @default(5000) // prix de la carte annuelle (CDC §5.4.1)
  updatedAt            DateTime @updatedAt
}

model MemberCard {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  academicYear String
  pricePaid    Int
  paymentMode  PaymentMode
  paymentRef   String?
  status       PaymentStatus @default(CONFIRMED)
  confirmedBy  String?
  confirmedAt  DateTime?
  rejectReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([userId, academicYear])
  @@index([status])
}

model MonthlyPayment {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  amountDue    Int
  amountPaid   Int
  paymentMode  PaymentMode
  paymentRef   String?
  status       PaymentStatus @default(CONFIRMED)
  confirmedBy  String?
  confirmedAt  DateTime?
  rejectReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([userId, year, month])
  @@index([status])
  @@index([userId])
}
